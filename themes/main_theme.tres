[gd_resource type="Theme" load_steps=10 format=3]

; Council theme — chrome-on-felt, brass-and-bone palette.
; Colors mirror scripts/Tokens.gd; keep them in sync if the tokens
; change (no .tres include support, so this is a manual mirror).
;
; FELT       #1a2024  felt
; BRASS      #c9a064  gilded frame, primary chrome
; BRASS_DIM  #8a6f3e  borders
; BONE       #e8dcc4  primary text
; BONE_DIM   #b9a98a  secondary text
; INK        #0a0e12  darkest, surface
; CANDLE     #f4d27a  hover highlight

