[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/Main.gd" id="1_main"]
[ext_resource type="Script" path="res://scripts/GameClient.gd" id="2_client"]
[ext_resource type="Script" path="res://scripts/HexMap.gd" id="3_hexmap"]

[node name="Main" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_main")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 16.0
offset_top = 16.0
offset_right = -16.0
offset_bottom = -16.0

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "foedus-godot — local play"
theme_override_font_sizes/font_size = 22

[node name="HBox" type="HBoxContainer" parent="VBox"]
layout_mode = 2

[node name="UrlLabel" type="Label" parent="VBox/HBox"]
layout_mode = 2
text = "play-server URL:  "

[node name="UrlEdit" type="LineEdit" parent="VBox/HBox"]
custom_minimum_size = Vector2(280, 0)
layout_mode = 2
text = "http://127.0.0.1:8090"

[node name="ConnectBtn" type="Button" parent="VBox"]
layout_mode = 2
text = "Connect (GET /healthz)"

[node name="StatusLabel" type="Label" parent="VBox"]
layout_mode = 2
text = "not connected"

[node name="CreateBtn" type="Button" parent="VBox"]
layout_mode = 2
text = "Create demo game (1 Heuristic + 3 Random)"

[node name="GamesLabel" type="Label" parent="VBox"]
layout_mode = 2
text = "(no active game)"

[node name="HBoxButtons" type="HBoxContainer" parent="VBox"]
layout_mode = 2

[node name="AdvanceBtn" type="Button" parent="VBox/HBoxButtons"]
layout_mode = 2
text = "Advance one turn"

[node name="AutoBtn" type="Button" parent="VBox/HBoxButtons"]
layout_mode = 2
text = "Auto-advance"

[node name="ViewBtn" type="Button" parent="VBox/HBoxButtons"]
layout_mode = 2
text = "Refresh view"

[node name="ViewSelect" type="HBoxContainer" parent="VBox"]
layout_mode = 2

[node name="ViewLabel" type="Label" parent="VBox/ViewSelect"]
layout_mode = 2
text = "viewing player:  "

[node name="ViewPlayerSpin" type="SpinBox" parent="VBox/ViewSelect"]
layout_mode = 2
max_value = 5.0
value = 0.0

[node name="HSplit" type="HSplitContainer" parent="VBox"]
layout_mode = 2
size_flags_vertical = 3
split_offset = 360

[node name="OutputLabel" type="RichTextLabel" parent="VBox/HSplit"]
custom_minimum_size = Vector2(300, 0)
layout_mode = 2
bbcode_enabled = true
text = "[i]waiting...[/i]"
fit_content = false

[node name="HexMap" type="Control" parent="VBox/HSplit"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
script = ExtResource("3_hexmap")
