[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/Main.gd" id="1_main"]
[ext_resource type="Script" path="res://scripts/GameClient.gd" id="2_client"]
[ext_resource type="Script" path="res://scripts/HexMap.gd" id="3_hexmap"]

[node name="Main" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_main")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 16.0
offset_top = 12.0
offset_right = -16.0
offset_bottom = -12.0

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "foedus — local play"
theme_override_font_sizes/font_size = 24

[node name="HBox" type="HBoxContainer" parent="VBox"]
layout_mode = 2

[node name="UrlLabel" type="Label" parent="VBox/HBox"]
layout_mode = 2
text = "play-server URL:  "

[node name="UrlEdit" type="LineEdit" parent="VBox/HBox"]
custom_minimum_size = Vector2(280, 0)
layout_mode = 2
text = "http://127.0.0.1:8090"

[node name="ConnectBtn" type="Button" parent="VBox/HBox"]
layout_mode = 2
text = "Connect"

[node name="StatusLabel" type="Label" parent="VBox"]
layout_mode = 2
text = "not connected"
autowrap_mode = 3
theme_override_colors/font_color = Color(0.78, 0.82, 0.92, 1)

[node name="GameOverBanner" type="PanelContainer" parent="VBox"]
visible = false
layout_mode = 2

[node name="GameOverLabel" type="Label" parent="VBox/GameOverBanner"]
layout_mode = 2
text = "GAME OVER"
horizontal_alignment = 1
theme_override_colors/font_color = Color(0.5, 0.86, 0.5, 1)
theme_override_font_sizes/font_size = 18

[node name="GameCreate" type="VBoxContainer" parent="VBox"]
layout_mode = 2

[node name="GameCreateLabel" type="Label" parent="VBox/GameCreate"]
layout_mode = 2
